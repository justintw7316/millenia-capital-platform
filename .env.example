# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── PostgreSQL / pgvector (required for production vector search) ─────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/millenia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=millenia

# ── Embedding model download ──────────────────────────────────────────────────
# Set to true to allow sentence-transformers to download BGE-M3 on first use.
# After the model is cached locally, you can set this back to false.
MATCHING_ALLOW_MODEL_DOWNLOAD=true

# ── Optional integrations (stub mode if not set) ──────────────────────────────
APOLLO_API_KEY=
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ACCESS_TOKEN=
BOX_FOLDER_ID=331277504511
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
MEETALFRED_API_KEY=

# ── API server ────────────────────────────────────────────────────────────────
API_SECRET_KEY=dev-secret
VITE_API_URL=http://localhost:8000
VITE_API_KEY=dev-secret

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
